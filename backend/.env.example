# Allowed frontend origins (comma-separated).
# Supports wildcard subdomain patterns like https://*.vercel.app
ALLOWED_ORIGINS=https://music.411710.xyz

# Trust X-Forwarded-For only if you are behind a trusted reverse proxy.
TRUST_PROXY_HEADERS=false

# Require Authorization: Bearer <API_TOKEN>
AUTH_REQUIRED=true
# Auth strategy:
# - bearer: require Bearer token from clients
# - origin: allow only requests from ALLOWED_ORIGINS
# - bearer_or_origin: allow either of the above
AUTH_STRATEGY=origin
API_TOKEN=change-me

# Metrics endpoint auth behavior (default true).
METRICS_REQUIRE_AUTH=true

# Endpoint-specific rate limits per IP per minute.
# 0 disables limiting.
RATE_LIMIT_PER_MINUTE=240
RATE_LIMIT_AUDIO_PER_MINUTE=180
RATE_LIMIT_SEARCH_PER_MINUTE=600

# Maximum accepted search query length.
MAX_QUERY_LENGTH=120

# Node process execution timeout.
NODE_TIMEOUT_SECONDS=20

# Response cache TTLs
AUDIO_CACHE_TTL_SECONDS=900
SEARCH_CACHE_TTL_SECONDS=180
SUGGEST_CACHE_TTL_SECONDS=60
METRICS_TTL_SECONDS=86400

# Redis (recommended for production scale)
REDIS_ENABLED=false
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_TIMEOUT_SECONDS=2.0
REDIS_KEY_PREFIX=music_backend:

# Optional explicit node binary path.
NODE_BINARY=node
