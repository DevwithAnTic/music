VITE_API_BASE_URL=http://localhost:8000
# Optional: only needed when backend AUTH_STRATEGY=bearer.
# Do not set this for browser deployments if backend uses AUTH_STRATEGY=origin.
VITE_API_TOKEN=
VITE_REQUIRE_AUTH=false
# Optional endpoint overrides (if not using VITE_API_BASE_URL)
# VITE_AUDIO_API_URL=https://api.example.com/getAudio.php
# VITE_SEARCH_API_URL=https://api.example.com/youtubeSearch.php
